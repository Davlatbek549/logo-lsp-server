TO SQUARE :size
  REPEAT 4 [FORWARD :size RIGHT 90]
END

TO TRIANGLE :size
  REPEAT 3 [FORWARD :size RIGHT 120]
END

TO POLYGON :sides :length
  MAKE "angle 360
  REPEAT :sides [FORWARD :length RIGHT :angle]
END

TO HOUSE :size
  LOCAL "roof
  MAKE "roof :size
  SQUARE :size
  TRIANGLE :roof
END

TO WALK :steps
  MAKE "stepSize 20
  REPEAT :steps [FORWARD :stepSize RIGHT 90]
END

TO STAR :size
  REPEAT 5 [FORWARD :size RIGHT 144]
END

TO FLOWER :petalSize
  REPEAT 8 [STAR :petalSize RIGHT 45]
END

MAKE "globalSize 50
MAKE "count 5

SQUARE :globalSize
TRIANGLE 40
HOUSE :globalSize
WALK :count
FLOWER 25
POLYGON 6 30

MAKE "x 100
PRINT :x
PRINT :globalSize

UNKNOWNPROC 10
PRINT :unknownVar

TO TESTLOCALS :a
  LOCAL "b
  MAKE "b :a
  PRINT :b
  PRINT :a
  PRINT :c
END

TESTLOCALS 15